---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Página no encontrada">
  <div class="min-h-screen bg-background flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="font-display font-black text-[10rem] leading-none text-transparent text-stroke-primary text-stroke-2 mb-4">404</h1>
      <p class="font-display font-semibold text-secondary text-xl mb-8">Página no encontrada</p>
      <a href="/" class="inline-block bg-primary hover:bg-felina-rosa-glow text-white font-display font-bold rounded-full px-8 py-3 transition-colors">
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
