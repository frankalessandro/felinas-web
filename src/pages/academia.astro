---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/shared/Navbar.astro";
import AboutSection from "../components/academia/AboutSection.astro";
import StatsSection from "../components/academia/StatsSection";
import ClassesSection from "../components/academia/ClassesSection";
import MembershipSection from "../components/academia/MembershipSection";
import FAQSection from "../components/academia/FAQSection.astro";
import CTASection from "../components/academia/CTASection.astro";
import Footer from "../components/shared/Footer.astro";
import WhatsAppButton from "../components/shared/WhatsAppButton.astro";
import HeroSpotlight from "../components/academia/HeroSpotlight";
import LoadingScreen from "../components/shared/LoadingScreen.astro";
import maeHeroImg from "../assets/academia/MaeHero_birefnet.webp";
import panterHeroImg from "../assets/academia/PanterHero_inspyrenet.webp";
---

<Layout title="Felinas Academia — Danza Urbana">
  <LoadingScreen />
  <div class="min-h-screen bg-black">
    <Navbar />
    <main>
      <HeroSpotlight client:only="react" bg1={maeHeroImg.src} bg2={panterHeroImg.src} />
      <AboutSection />
      <StatsSection client:visible />
      <ClassesSection client:visible />
      <MembershipSection client:visible />
      <FAQSection />
      <CTASection />
    </main>
    <Footer />
    <WhatsAppButton />
  </div>
</Layout>

<script>
  window.addEventListener("load", () => {
    // Doble rAF para que React tenga al menos un frame de pintura antes de quitar el loader
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const loader = document.getElementById("loading-screen");
        if (!loader) return;
        loader.style.transition = "opacity 0.9s ease";
        loader.style.opacity = "0";
        setTimeout(() => loader.remove(), 500);
      });
    });
  });
</script>
