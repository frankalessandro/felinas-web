---
const WHATSAPP_URL = "https://wa.me/573027451752?text=%C2%A1Hola!%20Quiero%20agendar%20mi%20clase%20en%20Felinas";
const navLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Clases", href: "#clases" },
  { label: "Membresías", href: "#membresias" },
  { label: "Comunidad", href: "#comunidad" },
  { label: "Contacto", href: "#contacto" },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-black">
  <nav class="container flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2 group nav-link">
      <img src="/assets/PanteraFelinasLogo.svg" alt="Felinas Logo" class="h-8 md:h-10 object-contain transition-all" />
      <span class="font-display font-black text-2xl md:text-3xl tracking-tight text-white group-hover:text-primary transition-colors">
        FELINAS
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((l) => (
        <li>
          <a
            href={l.href}
            class="text-sm font-medium text-white/80 hover:text-primary transition-colors nav-link"
          >
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary hover:bg-felina-rosa-glow text-white font-display font-bold rounded-full px-6 py-2.5 text-sm transition-colors"
        >
          Agenda tu clase
        </a>
      </li>
    </ul>

    <button id="menu-toggle" class="md:hidden text-white p-2" aria-label="Menú">
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden backdrop-blur-lg" style="background: rgba(10,10,10,0.98);">
    <ul class="flex flex-col items-center gap-6 py-8">
      {navLinks.map((l) => (
        <li>
          <a
            href={l.href}
            class="text-lg font-display font-semibold text-white/90 hover:text-primary transition-colors nav-link"
          >
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-primary hover:bg-felina-rosa-glow text-white font-display font-bold rounded-full px-8 py-3 text-base transition-colors"
        >
          Agenda tu clase
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const menuToggle = document.getElementById("menu-toggle")!;
  const iconMenu = document.getElementById("icon-menu")!;
  const iconClose = document.getElementById("icon-close")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar.style.backdropFilter = "blur(12px)";
      navbar.style.boxShadow = "0 4px 20px rgba(0,0,0,0.3)";
    } else {
      navbar.style.backdropFilter = "";
      navbar.style.boxShadow = "";
    }
  });

  menuToggle.addEventListener("click", () => {
    const isOpen = !mobileMenu.classList.contains("hidden");
    mobileMenu.classList.toggle("hidden");
    iconMenu.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
  });

  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = (link as HTMLAnchorElement).getAttribute("href");
      if (href?.startsWith("#")) {
        e.preventDefault();
        mobileMenu.classList.add("hidden");
        iconMenu.classList.remove("hidden");
        iconClose.classList.add("hidden");
        document.querySelector(href)?.scrollIntoView({ behavior: "smooth" });
      }
    });
  });
</script>
