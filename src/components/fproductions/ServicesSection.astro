---
const services = [
  {
    tag: "Lo más pedido",
    title: "Shows en vivo",
    desc: "Presentaciones de alto impacto para discotecas, bares y eventos. Coreografías originales, vestuario y energía que prende la pista.",
    points: ["Discotecas & bares", "Aperturas y cierres", "Coreografías temáticas"],
    featured: true,
  },
  {
    tag: null,
    title: "Acompañamiento de eventos",
    desc: "Estamos contigo de principio a fin: animación, ambientación y presencia escénica durante todo tu evento.",
    points: ["Animación", "Recibimiento", "Hora loca"],
    featured: false,
  },
  {
    tag: null,
    title: "Activaciones de marca",
    desc: "Llevamos tu marca al escenario con experiencias que conectan con tu público y se vuelven contenido.",
    points: ["Lanzamientos", "Ferias & expos", "Contenido viral"],
    featured: false,
  },
  {
    tag: null,
    title: "Producción a medida",
    desc: "Concepto, música, vestuario y puesta en escena diseñados desde cero para tu ocasión especial.",
    points: ["Concepto único", "Dirección escénica", "Eventos privados"],
    featured: false,
  },
];
---

<section id="servicios" class="relative py-24 md:py-36 bg-[#07030b] border-t border-white/5 overflow-hidden">
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] rounded-full bg-[#ff006a]/10 blur-[130px] pointer-events-none"></div>
  <div class="absolute top-0 left-1/3 w-[300px] h-[300px] rounded-full bg-felina-morado/15 blur-[100px] pointer-events-none"></div>

  <div class="container px-4 md:px-8 relative z-10">
    <div data-reveal class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 md:mb-20">
      <div>
        <p class="font-display font-semibold text-[#ff006a] text-xs tracking-[0.35em] uppercase mb-5 flex items-center gap-3">
          <span class="w-10 h-px bg-[#ff006a]"></span> Qué hacemos
        </p>
        <h2 class="font-display font-black text-4xl md:text-6xl text-white tracking-tighter leading-none">
          NUESTROS<br /><span class="text-transparent" style="-webkit-text-stroke: 1.5px #ff006a;">SERVICIOS</span>
        </h2>
      </div>
      <p class="text-white/60 max-w-sm text-sm md:text-base leading-relaxed">
        Cada formato se adapta a tu espacio, presupuesto y público. Dinos qué imaginas y lo hacemos realidad.
      </p>
    </div>

    <div class="flex flex-col divide-y divide-white/8">
      {services.map((s) => (
        <div
          data-reveal
          class="group relative flex flex-col md:flex-row md:items-center gap-4 md:gap-0 py-8 md:py-10 cursor-default overflow-hidden transition-all duration-300"
        >
          <!-- flood layer -->
          <div class="absolute inset-0 bg-[#ff006a] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] z-0"></div>

          <!-- Title -->
          <div class="relative z-10 flex-1 md:min-w-[280px]">
            <div class="flex items-center gap-3">
              <h3 class="font-display font-black text-2xl md:text-4xl pl-4 text-white group-hover:text-black tracking-tight transition-colors duration-300 leading-none">
                {s.title}
              </h3>
              {s.tag && (
                <span class="hidden md:inline-flex text-[9px] font-bold uppercase tracking-[0.2em] text-[#ff006a] group-hover:text-black group-hover:border-black/30 bg-[#ff006a]/15 group-hover:bg-black/10 border border-[#ff006a]/30 px-3 py-1 transition-colors duration-300">
                  {s.tag}
                </span>
              )}
            </div>
          </div>

          <!-- Desc + tags -->
          <div class="relative z-10 flex-1 max-w-lg">
            <p class="text-sm md:text-base text-white/70 group-hover:text-black leading-relaxed mb-4 transition-colors duration-300">{s.desc}</p>
            <ul class="flex flex-wrap gap-2">
              {s.points.map((pt) => (
                <li class="text-[11px] font-semibold uppercase tracking-wide text-white/70 group-hover:text-black bg-white/5 group-hover:bg-black/10 border border-white/15 group-hover:border-black/25 px-3 py-1 transition-colors duration-300">
                  {pt}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
