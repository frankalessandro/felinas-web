---
const WHATSAPP_URL =
  "https://wa.me/573203426558?text=%C2%A1Hola!%20Quiero%20información%20sobre%20Felinas%20F%20Productions";
const links = [
  { label: "Nosotras", href: "#nosotras" },
  { label: "Servicios", href: "#servicios" },
  { label: "Por qué", href: "#por-que" },
  { label: "Galería", href: "#galeria" },
];
---

<footer class="bg-[#050208] text-white/70 pt-16 pb-8 border-t border-white/5">
  <div class="container px-4 md:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/assets/PanteraFelinasLogo.svg" alt="Felinas" class="w-11" />
          <h3 class="font-display font-black text-xl text-white tracking-wide">F·PRODUCTIONS</h3>
        </div>
        <p class="text-sm leading-relaxed text-white/65 max-w-xs">
          El grupo de shows en vivo de Felinas. Energía, baile y producción para tu evento.
        </p>
      </div>

      <div>
        <h4 class="font-display font-bold text-sm text-white mb-4 uppercase tracking-wider">Explora</h4>
        <ul class="space-y-2 text-sm">
          {links.map((l) => (
            <li><a href={l.href} class="text-white/65 hover:text-felina-morado transition-colors">{l.label}</a></li>
          ))}
          <li><a href="/academia" class="text-white/55 hover:text-felina-morado transition-colors">Academia</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold text-sm text-white mb-4 uppercase tracking-wider">Síguenos</h4>
        <div class="flex gap-3">
          <a href="https://instagram.com/felinas.oficial" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 hover:bg-felina-morado flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
          </a>
          <a href="https://tiktok.com/@felinas.oficial" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 hover:bg-felina-morado flex items-center justify-center transition-colors" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px]"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.88-2.89 2.89 2.89 0 012.88-2.89c.28 0 .56.04.81.12V9.01a6.26 6.26 0 00-.81-.05A6.34 6.34 0 003.15 15.3a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.37a8.16 8.16 0 004.76 1.52V7.43a4.85 4.85 0 01-1-.74z" /></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-display font-bold text-sm text-white mb-4 uppercase tracking-wider">Contrataciones</h4>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm hover:text-felina-morado transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
          +57 302 342 6558
        </a>
        <p class="text-sm mt-2 text-white/55">@felinas.oficial</p>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 text-center text-xs text-white/45">
      © {new Date().getFullYear()} Felinas · F Productions — Todos los derechos reservados
    </div>
  </div>
</footer>
