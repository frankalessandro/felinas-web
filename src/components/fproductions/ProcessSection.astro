---
const steps = [
  { n: "1", t: "Conversamos tu idea", d: "Nos cuentas qué evento tienes, la fecha y la vibra que buscas. Sin compromiso." },
  { n: "2", t: "Diseñamos el concepto", d: "Proponemos formato, música, vestuario y duración pensados para tu público." },
  { n: "3", t: "Ensayamos y producimos", d: "Coordinamos cada detalle técnico con tu equipo y dejamos todo listo." },
  { n: "4", t: "Brillamos en tu evento", d: "Llegamos, encendemos la escena y te acompañamos de principio a fin." },
];
---

<section id="proceso" class="relative py-24 md:py-36 bg-[#07030b] border-t border-white/5 overflow-hidden">
  <div class="absolute bottom-0 left-1/3 w-[500px] h-[500px] rounded-full bg-purple-900/20 blur-[130px]"></div>

  <div class="container px-4 md:px-8 relative z-10">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16 md:mb-24">
      <p class="font-display font-semibold text-purple-400 text-xs tracking-[0.35em] uppercase mb-5">Acompañamiento total</p>
      <h2 class="font-display font-black text-4xl md:text-6xl text-white tracking-tighter leading-[0.95]">
        ASÍ <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-300 to-felina-morado">TRABAJAMOS</span>
      </h2>
      <p class="text-white/45 text-base md:text-lg mt-6 leading-relaxed">
        No te dejamos solo. Desde el primer mensaje hasta el último aplauso, estamos contigo.
      </p>
    </div>

    <div class="relative grid md:grid-cols-4 gap-8 md:gap-5">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-7 left-[12%] right-[12%] h-px bg-gradient-to-r from-transparent via-felina-morado/40 to-transparent"></div>

      {steps.map((s) => (
        <div data-reveal class="relative flex flex-col items-center text-center md:items-start md:text-left">
          <div class="w-14 h-14 rounded-2xl bg-[#0c0512] border border-felina-morado/40 flex items-center justify-center mb-6 relative z-10 shadow-[0_0_30px_rgba(124,4,117,0.3)]">
            <span class="font-display font-black text-2xl text-transparent bg-clip-text bg-gradient-to-br from-white to-felina-morado">{s.n}</span>
          </div>
          <h3 class="font-display font-bold text-lg text-white mb-3">{s.t}</h3>
          <p class="text-sm text-white/50 leading-relaxed max-w-[240px] md:max-w-none">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>
