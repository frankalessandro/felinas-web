---
const steps = [
  { t: "Conversamos tu idea",     d: "Nos cuentas qué evento tienes, la fecha y la vibra que buscas. Sin compromiso." },
  { t: "Diseñamos el concepto",   d: "Proponemos formato, música, vestuario y duración pensados para tu público." },
  { t: "Ensayamos y producimos",  d: "Coordinamos cada detalle técnico con tu equipo y dejamos todo listo." },
  { t: "Brillamos en tu evento",  d: "Llegamos, encendemos la escena y te acompañamos de principio a fin." },
];
---

<section id="proceso" class="relative bg-[#07030b] border-t border-white/5 overflow-hidden">
  <!-- Ambient glows -->
  <div class="absolute top-1/4 -left-40 w-[700px] h-[700px] rounded-full bg-felina-morado/12 blur-[180px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 -right-40 w-[600px] h-[600px] rounded-full bg-[#ff006a]/8 blur-[160px] pointer-events-none"></div>
  <div class="absolute top-2/3 left-1/3 w-[400px] h-[400px] rounded-full bg-purple-900/15 blur-[120px] pointer-events-none"></div>

  <div class="container px-4 md:px-8 relative z-10 max-w-5xl mx-auto">

    <!-- ── Header ── -->
    <div data-reveal class="pt-28 md:pt-44 pb-24 md:pb-36">
      <p class="font-display font-semibold text-purple-400 text-xs tracking-[0.35em] uppercase mb-6 flex items-center gap-3">
        <span class="w-10 h-px bg-purple-400/50"></span> Acompañamiento total
      </p>
      <h2 class="font-display font-black tracking-tighter leading-[0.88]" style="font-size: clamp(3rem, 9vw, 7rem);">
        <span class="text-white block">ASÍ</span>
        <span class="block text-transparent" style="-webkit-text-stroke: 2px rgba(148,50,210,0.65);">TRABAJAMOS</span>
      </h2>
      <p class="text-white/60 text-base md:text-lg mt-8 max-w-md leading-relaxed">
        No te dejamos solos. Desde el primer mensaje hasta el último aplauso, estamos contigo.
      </p>
    </div>

    <!-- ── Steps ── -->
    <div id="process-steps" class="relative pb-28 md:pb-44">

      <!-- Track base -->
      <div class="absolute left-[11px] md:left-[13px] top-0 bottom-0 w-[1px] bg-white/6 hidden md:block"></div>
      <!-- Track fill -->
      <div id="process-fill"
        class="absolute left-[11px] md:left-[13px] top-0 w-[1px] bg-gradient-to-b from-felina-morado via-purple-500 to-[#ff006a] hidden md:block pointer-events-none"
        style="height: 0; will-change: height;">
      </div>

      {steps.map((s, i) => (
        <div
          class="process-step group relative flex items-start gap-8 md:gap-20 py-16 md:py-24 border-b border-white/[0.04] last:border-b-0"
          data-i={String(i)}
        >
          <!-- Node -->
          <div class="hidden md:block shrink-0 pt-1 relative z-10">
            <div class="step-node w-[27px] h-[27px] rounded-full border border-white/12 bg-[#07030b] flex items-center justify-center relative transition-all duration-600">
              <div class="step-dot w-[9px] h-[9px] rounded-full bg-white/15 transition-all duration-600"></div>
              <div class="step-ring absolute inset-[-4px] rounded-full border border-transparent transition-all duration-600"></div>
            </div>
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0 relative">

            <!-- Ghost diamond decoration -->
            <div class="step-ghost absolute -right-2 md:right-0 top-1/2 -translate-y-[55%] font-display font-black leading-none select-none pointer-events-none"
              style="font-size: clamp(7rem, 22vw, 18rem); color: transparent; -webkit-text-stroke: 1px rgba(124,4,117,0.0); opacity: 0; transform: translateY(-55%) scale(0.92); transition: opacity 1s ease, transform 1s ease, -webkit-text-stroke 1s ease;">
              ◆
            </div>

            <!-- Accent top line -->
            <div class="step-line h-px bg-gradient-to-r from-felina-morado/70 to-transparent mb-7 transition-all duration-700 ease-out" style="width: 0;"></div>

            <!-- Title -->
            <h3 class="step-title font-display font-black tracking-tight leading-[0.95] mb-5 transition-colors duration-500 group-hover:text-white"
              style="font-size: clamp(1.9rem, 5.5vw, 4rem); color: rgba(255,255,255,0.11); filter: blur(5px); transition: color .5s, filter .7s ease, text-shadow .5s;">
              {s.t}
            </h3>

            <!-- Desc -->
            <p class="step-desc text-base md:text-lg leading-relaxed max-w-md transition-all duration-700"
              style="color: rgba(255,255,255,0); filter: blur(4px);">
              {s.d}
            </p>

            <!-- Hover glow -->
            <div class="absolute inset-0 -left-6 -right-6 bg-gradient-to-r from-felina-morado/0 via-felina-morado/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none rounded-lg"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .step-title {
    transition: color 0.5s ease, filter 0.7s ease, text-shadow 0.5s ease;
  }
  .step-desc {
    transition: color 0.7s ease 0.15s, filter 0.7s ease 0.15s;
  }
  .process-step.is-active .step-line {
    width: 80px;
  }
  .process-step.is-active .step-title {
    color: rgba(255, 255, 255, 0.92) !important;
    filter: blur(0px) !important;
  }
  .process-step.is-active .step-desc {
    color: rgba(255, 255, 255, 0.65) !important;
    filter: blur(0px) !important;
  }
  .process-step.is-active .step-dot {
    background-color: #9333ea;
    box-shadow: 0 0 16px 4px rgba(124, 4, 117, 0.75);
    transform: scale(1.2);
  }
  .process-step.is-active .step-ring {
    border-color: rgba(124, 4, 117, 0.5);
    transform: scale(1.3);
  }
  .process-step.is-active .step-ghost {
    opacity: 1 !important;
    transform: translateY(-55%) scale(1) !important;
    -webkit-text-stroke: 1px rgba(124, 4, 117, 0.14) !important;
  }
  .process-step:hover .step-title {
    text-shadow: 0 0 60px rgba(124, 4, 117, 0.5);
  }
  .process-step:hover .step-dot {
    background-color: #ff006a !important;
    box-shadow: 0 0 20px 6px rgba(255, 0, 106, 0.6) !important;
  }
</style>

<script>
  const section = document.getElementById("process-steps");
  const steps = section?.querySelectorAll<HTMLElement>(".process-step");
  const fill = document.getElementById("process-fill") as HTMLElement | null;

  if (!steps || !section) throw new Error("process section not found");

  // ── IntersectionObserver: activate each step ──
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-active");
        }
      });
    },
    { threshold: 0.25, rootMargin: "0px 0px -80px 0px" }
  );

  steps.forEach((s) => io.observe(s));

  // ── Scroll: fill vertical track ──
  function updateFill() {
    if (!fill || !section) return;
    const rect = section.getBoundingClientRect();
    const winH = window.innerHeight;
    // how far we've scrolled through the section (0 → 1)
    const progress = Math.max(0, Math.min(1, (winH - rect.top) / (rect.height + winH)));
    fill.style.height = `${progress * 100}%`;
  }

  window.addEventListener("scroll", updateFill, { passive: true });
  updateFill();
</script>
