---
const values = [
  { label: "Empoderamiento femenino", icon: "sparkles" },
  { label: "Autoconfianza sin límites", icon: "heart" },
  { label: "Conexión con tu cuerpo", icon: "music" },
  { label: "Comunidad auténtica", icon: "users" },
];
---

<section id="comunidad-section" class="py-24 md:py-32 bg-background relative overflow-hidden">
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[100px] translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute top-10 right-10 opacity-[0.03] pointer-events-none select-none">
    <h2 class="font-display font-black text-[10rem] md:text-[15rem] leading-[0.8]">ABOUT<br />US</h2>
  </div>

  <div data-reveal class="container px-4 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

      <div class="w-full lg:w-1/2 relative min-h-[500px] md:min-h-[600px] flex items-center justify-center">
        <div class="absolute inset-0 bg-secondary/5 rounded-full blur-3xl"></div>
        <div class="w-[85%] aspect-[3/4] md:aspect-square bg-secondary rounded-[3rem] md:rounded-[5rem] rounded-tr-[10rem] md:rounded-tr-[15rem] overflow-hidden border border-border/50 relative z-20 shadow-2xl">
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent mix-blend-overlay"></div>
          <div class="w-full h-full bg-secondary/80 flex items-center justify-center p-8 text-center text-muted-foreground">
            <div class="border border-dashed border-primary/20 p-8 rounded-[2rem] rounded-tr-[5rem] w-full h-full flex items-center justify-center">
              <span class="font-display uppercase tracking-widest text-sm">Fotografía de<br />Comunidad</span>
            </div>
          </div>
        </div>
        <div class="absolute bottom-4 -left-4 md:left-4 bg-background border border-border p-4 md:p-6 rounded-2xl shadow-xl z-30 animate-bounce-subtle">
          <p class="font-display font-black text-4xl md:text-5xl text-foreground">
            100<span class="text-primary">%</span>
          </p>
<h1>Hola</h1>
          <p class="text-xs uppercase tracking-widest text-muted-foreground mt-1 font-bold">Actitud Felina</p>
        </div>
        <div class="absolute top-0 right-10 w-32 h-32 rounded-full border border-primary/30 pointer-events-none scale-150 -z-10"></div>
      </div>

      <div class="w-full lg:w-1/2 relative">
        <div class="w-24 h-1 bg-primary mb-8"></div>
        <p class="font-display font-semibold text-primary text-sm tracking-[0.4em] uppercase mb-4">Nuestra esencia</p>
        <h2 class="font-display font-black text-5xl md:text-6xl leading-[1] mb-8">
          <span class="text-foreground">MÁS QUE UNA</span><br />
          <span class="text-transparent text-stroke-secondary text-stroke-2">ACADEMIA,</span><br />
          <span class="text-gradient-pink italic pr-4"> UNA COMUNIDAD</span>
        </h2>
        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed mb-10 font-light max-w-lg">
          Felinas nació con la idea de crear un espacio donde las personas puedan expresarse con libertad, fortalecer su confianza y descubrir nuevas formas de conectar a través de la danza. 
          Un lugar donde cada proceso es bienvenido, sin importar la experiencia o el nivel.
        </p>

        <div class="flex flex-col gap-6 relative">
          <div class="absolute left-[19px] top-6 bottom-6 w-px bg-border -z-10"></div>
          {values.map((v) => (
            <div class="flex items-center gap-6 group">
              <div class="w-10 h-10 rounded-full bg-background border border-primary/30 flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:border-primary transition-colors duration-300 shadow-sm">
                {v.icon === "sparkles" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors">
                    <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
                  </svg>
                )}
                {v.icon === "heart" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                )}
                {v.icon === "music" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors">
                    <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                  </svg>
                )}
                {v.icon === "users" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary group-hover:text-white transition-colors">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                )}
              </div>
              <span class="text-base md:text-lg font-medium text-foreground group-hover:text-primary transition-colors cursor-default">
                {v.label}
              </span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const el = document.querySelector("[data-reveal]") as HTMLElement | null;
  if (el) {
    el.style.opacity = "0";
    el.style.transform = "translateY(30px)";
    el.style.transition = "opacity 0.6s ease-out, transform 0.6s ease-out";
    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        obs.unobserve(el);
      }
    }, { threshold: 0.15 });
    obs.observe(el);
  }
</script>
